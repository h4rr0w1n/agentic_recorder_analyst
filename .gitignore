```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Dependencies
node_modules/

# Build artifacts
dist/
build/
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Cache directories
.mypy_cache/
.pytest_cache/
```